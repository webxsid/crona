$ErrorActionPreference = "Stop"

$Version = "__VERSION__"
$Repo = "__REPO__"

function Get-InstallDir {
    if ($env:CRONA_INSTALL_DIR -and $env:CRONA_INSTALL_DIR.Trim() -ne "") {
        return $env:CRONA_INSTALL_DIR.Trim()
    }

    $localAppData = $env:LOCALAPPDATA
    if (-not $localAppData -or $localAppData.Trim() -eq "") {
        $localAppData = Join-Path $HOME "AppData\Local"
    }
    return Join-Path $localAppData "Programs\Crona\bin"
}

function Get-RuntimeDir {
    if ($env:CRONA_HOME -and $env:CRONA_HOME.Trim() -ne "") {
        return $env:CRONA_HOME.Trim()
    }

    $localAppData = $env:LOCALAPPDATA
    if (-not $localAppData -or $localAppData.Trim() -eq "") {
        $localAppData = Join-Path $HOME "AppData\Local"
    }
    return Join-Path $localAppData "Crona"
}

function Get-ArchSuffix {
    $arch = $env:PROCESSOR_ARCHITECTURE
    if ($env:PROCESSOR_ARCHITEW6432 -and $env:PROCESSOR_ARCHITEW6432.Trim() -ne "") {
        $arch = $env:PROCESSOR_ARCHITEW6432
    }

    switch ($arch.ToUpperInvariant()) {
        "ARM64" { return "arm64" }
        "AMD64" { return "amd64" }
        default { throw "Unsupported architecture: $arch" }
    }
}

function Add-InstallDirToUserPath([string]$InstallDir) {
    $userPath = [Environment]::GetEnvironmentVariable("Path", "User")
    $parts = @()
    if ($userPath) {
        $parts = $userPath.Split(';') | Where-Object { $_ -and $_.Trim() -ne "" }
    }

    foreach ($part in $parts) {
        if ([string]::Equals($part.TrimEnd('\'), $InstallDir.TrimEnd('\'), [System.StringComparison]::OrdinalIgnoreCase)) {
            if ($env:Path -notmatch [regex]::Escape($InstallDir)) {
                $env:Path = "$InstallDir;$env:Path"
            }
            return
        }
    }

    $newPath = if ($userPath -and $userPath.Trim() -ne "") { "$userPath;$InstallDir" } else { $InstallDir }
    [Environment]::SetEnvironmentVariable("Path", $newPath, "User")
    $env:Path = "$InstallDir;$env:Path"
}

function Stop-RunningKernel([string]$RuntimeDir) {
    $infoFile = Join-Path $RuntimeDir "kernel.json"
    if (-not (Test-Path $infoFile)) {
        return
    }

    try {
        $info = Get-Content $infoFile -Raw | ConvertFrom-Json
    } catch {
        return
    }

    if (-not $info.pid) {
        return
    }

    $process = Get-Process -Id $info.pid -ErrorAction SilentlyContinue
    if (-not $process) {
        Remove-Item $infoFile -ErrorAction SilentlyContinue
        Remove-Item (Join-Path $RuntimeDir "kernel.sock") -ErrorAction SilentlyContinue
        return
    }

    if ($process.ProcessName -notlike "*crona-kernel*") {
        throw "Refusing to stop pid $($info.pid); kernel.json does not point at a Crona kernel process."
    }

    Write-Host "Stopping running Crona kernel (pid $($info.pid)) before install"
    Stop-Process -Id $info.pid -Force
    Remove-Item $infoFile -ErrorAction SilentlyContinue
}

function Verify-Checksum([string]$FilePath, [string]$ExpectedHash) {
    $actualHash = (Get-FileHash -Algorithm SHA256 -Path $FilePath).Hash.ToLowerInvariant()
    if ($actualHash -ne $ExpectedHash.ToLowerInvariant()) {
        throw "Checksum mismatch for $(Split-Path $FilePath -Leaf)"
    }
}

function Get-ExpectedChecksum([string]$ChecksumsPath, [string]$AssetName) {
    foreach ($line in Get-Content $ChecksumsPath) {
        if (-not $line) {
            continue
        }
        $parts = $line -split "\s+"
        if ($parts.Length -lt 2) {
            continue
        }
        if ($parts[-1] -eq $AssetName) {
            return $parts[0]
        }
    }
    throw "checksums.txt is missing $AssetName"
}

function Format-ByteSize([long]$Bytes) {
    if ($Bytes -lt 0) {
        return "0 B"
    }
    if ($Bytes -lt 1KB) {
        return "$Bytes B"
    }
    if ($Bytes -lt 1MB) {
        return ("{0:N1} KB" -f ($Bytes / 1KB))
    }
    if ($Bytes -lt 1GB) {
        return ("{0:N1} MB" -f ($Bytes / 1MB))
    }
    return ("{0:N1} GB" -f ($Bytes / 1GB))
}

function Download-Asset([string]$Label, [string]$Url, [string]$OutFile) {
    Write-Host "Downloading $Label..."
    $activity = "Downloading $Label"
    $handler = [System.Net.Http.HttpClientHandler]::new()
    $client = [System.Net.Http.HttpClient]::new($handler)
    try {
        $response = $client.GetAsync($Url, [System.Net.Http.HttpCompletionOption]::ResponseHeadersRead).GetAwaiter().GetResult()
        $response.EnsureSuccessStatusCode()
        $contentLength = $response.Content.Headers.ContentLength
        $input = $response.Content.ReadAsStreamAsync().GetAwaiter().GetResult()
        $output = [System.IO.File]::Open($OutFile, [System.IO.FileMode]::Create, [System.IO.FileAccess]::Write, [System.IO.FileShare]::None)
        try {
            $buffer = New-Object byte[] 65536
            $downloaded = [long]0
            while (($read = $input.Read($buffer, 0, $buffer.Length)) -gt 0) {
                $output.Write($buffer, 0, $read)
                $downloaded += $read
                if ($contentLength -and $contentLength -gt 0) {
                    $percent = [int][Math]::Floor(($downloaded * 100.0) / $contentLength)
                    if ($percent -gt 100) {
                        $percent = 100
                    }
                    $status = "{0} / {1}" -f (Format-ByteSize $downloaded), (Format-ByteSize $contentLength)
                    Write-Progress -Activity $activity -Status $status -PercentComplete $percent
                } else {
                    $status = "{0} downloaded" -f (Format-ByteSize $downloaded)
                    Write-Progress -Activity $activity -Status $status -PercentComplete -1
                }
            }
            $output.Flush()
            Write-Progress -Activity $activity -Completed
        }
        finally {
            if ($output) {
                $output.Dispose()
            }
            if ($input) {
                $input.Dispose()
            }
            $response.Dispose()
        }
    }
    finally {
        $client.Dispose()
        $handler.Dispose()
    }
}

$installDir = Get-InstallDir
$runtimeDir = Get-RuntimeDir
$assetsDir = Join-Path $runtimeDir "assets\bundled"
$archSuffix = Get-ArchSuffix
$baseUrl = "https://github.com/$Repo/releases/download/$Version"
$bundleName = "crona-bundle-$Version-windows-$archSuffix.zip"
$assetsName = "crona-assets-$Version.tar.gz"
$checksumsName = "checksums.txt"

New-Item -ItemType Directory -Force -Path $installDir | Out-Null
New-Item -ItemType Directory -Force -Path $assetsDir | Out-Null
Stop-RunningKernel $runtimeDir

$tmpDir = Join-Path ([System.IO.Path]::GetTempPath()) ("crona-install-" + [System.Guid]::NewGuid().ToString("N"))
New-Item -ItemType Directory -Force -Path $tmpDir | Out-Null

try {
    $checksumsPath = Join-Path $tmpDir $checksumsName
    $bundlePath = Join-Path $tmpDir $bundleName
    $assetsPath = Join-Path $tmpDir $assetsName
    $bundleDir = Join-Path $tmpDir "bundle"

    Write-Host "Installing Crona $Version to $installDir"
    Download-Asset "checksums" "$baseUrl/$checksumsName" $checksumsPath
    Download-Asset "bundle" "$baseUrl/$bundleName" $bundlePath
    Download-Asset "assets" "$baseUrl/$assetsName" $assetsPath

    Write-Host "Verifying checksums..."
    Verify-Checksum $bundlePath (Get-ExpectedChecksum $checksumsPath $bundleName)
    Verify-Checksum $assetsPath (Get-ExpectedChecksum $checksumsPath $assetsName)

    Expand-Archive -Path $bundlePath -DestinationPath $bundleDir -Force
    $cliPath = Join-Path $bundleDir "crona-$Version-windows-$archSuffix.exe"
    $kernelPath = Join-Path $bundleDir "crona-kernel-$Version-windows-$archSuffix.exe"
    $tuiPath = Join-Path $bundleDir "crona-tui-$Version-windows-$archSuffix.exe"

    Write-Host "Installing binaries..."
    Move-Item -Force $cliPath (Join-Path $installDir "crona.exe")
    Move-Item -Force $kernelPath (Join-Path $installDir "crona-kernel.exe")
    Move-Item -Force $tuiPath (Join-Path $installDir "crona-tui.exe")

    $exportDir = Join-Path $assetsDir "export"
    if (Test-Path $exportDir) {
        Remove-Item -Recurse -Force $exportDir
    }

    Write-Host "Extracting bundled assets..."
    tar -xzf $assetsPath -C $assetsDir
    Add-InstallDirToUserPath $installDir

    Write-Host ""
    Write-Host "Installed:"
    Write-Host "  $(Join-Path $installDir 'crona.exe')"
    Write-Host "  $(Join-Path $installDir 'crona-kernel.exe')"
    Write-Host "  $(Join-Path $installDir 'crona-tui.exe')"
    Write-Host "  runtime data: $runtimeDir"
    Write-Host "  $exportDir"
    Write-Host ""
    Write-Host "Open a new PowerShell session if PATH changes are not visible yet."
    Write-Host "Then run:"
    Write-Host "  crona"
}
finally {
    if (Test-Path $tmpDir) {
        Remove-Item -Recurse -Force $tmpDir
    }
}
