#!/usr/bin/env sh
set -eu

VERSION="__VERSION__"
REPO="__REPO__"
INSTALL_DIR="${CRONA_INSTALL_DIR:-$HOME/.local/bin}"
VERSION_FILE="${INSTALL_DIR}/.crona-version"
TMP_DIR=""

cleanup() {
  if [ -n "${TMP_DIR}" ] && [ -d "${TMP_DIR}" ]; then
    rm -rf "${TMP_DIR}"
  fi
}

trap cleanup EXIT INT TERM

default_crona_home() {
  case "${OS}" in
    darwin)
      printf '%s\n' "${HOME}/Library/Application Support/Crona"
      ;;
    linux)
      if [ -n "${XDG_DATA_HOME:-}" ]; then
        printf '%s\n' "${XDG_DATA_HOME}/crona"
      else
        printf '%s\n' "${HOME}/.local/share/crona"
      fi
      ;;
  esac
}

legacy_crona_home() {
  printf '%s\n' "${HOME}/.crona"
}

stop_running_kernel_at() {
  runtime_home="$1"
  info_file="${runtime_home}/kernel.json"
  socket_file="${runtime_home}/kernel.sock"

  if [ ! -f "${info_file}" ]; then
    return 0
  fi

  kernel_pid="$(sed -n 's/.*"pid"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p' "${info_file}" | head -n 1)"
  if [ -z "${kernel_pid}" ]; then
    return 0
  fi

  if ! kill -0 "${kernel_pid}" 2>/dev/null; then
    rm -f "${info_file}" "${socket_file}"
    return 0
  fi

  kernel_cmd="$(ps -p "${kernel_pid}" -o command= 2>/dev/null || true)"
  case "${kernel_cmd}" in
    *crona-kernel*)
      ;;
    *)
      echo "Refusing to stop pid ${kernel_pid}; kernel.json does not point at a Crona kernel process." >&2
      return 1
      ;;
  esac

  echo "Stopping running Crona kernel (pid ${kernel_pid}) before install"
  kill "${kernel_pid}" 2>/dev/null || true

  wait_count=0
  while kill -0 "${kernel_pid}" 2>/dev/null; do
    wait_count=$((wait_count + 1))
    if [ "${wait_count}" -ge 10 ]; then
      echo "Crona kernel did not stop cleanly; sending SIGKILL"
      kill -9 "${kernel_pid}" 2>/dev/null || true
      break
    fi
    sleep 1
  done

  rm -f "${info_file}" "${socket_file}"
}

migrate_legacy_runtime_dir() {
  if [ "${CRONA_HOME_IS_OVERRIDE}" = "1" ]; then
    return 0
  fi
  if [ "${CRONA_HOME}" = "${LEGACY_CRONA_HOME}" ]; then
    return 0
  fi
  if [ -d "${CRONA_HOME}" ]; then
    return 0
  fi
  if [ ! -d "${LEGACY_CRONA_HOME}" ]; then
    return 0
  fi

  stop_running_kernel_at "${LEGACY_CRONA_HOME}"
  mkdir -p "$(dirname "${CRONA_HOME}")"
  echo "Migrating Crona runtime data from ${LEGACY_CRONA_HOME} to ${CRONA_HOME}"
  mv "${LEGACY_CRONA_HOME}" "${CRONA_HOME}"
}

prompt_replace() {
  installed_version="$1"

  if [ "${CRONA_INSTALL_FORCE:-0}" = "1" ]; then
    return 0
  fi

  if [ -n "${installed_version}" ]; then
    if [ "${installed_version}" = "${VERSION}" ]; then
      printf 'Crona %s is already installed in %s.\n' "${installed_version}" "${INSTALL_DIR}"
      printf 'Reinstall %s? [y/N] ' "${VERSION}"
    else
      printf 'Crona %s is already installed in %s.\n' "${installed_version}" "${INSTALL_DIR}"
      printf 'Install %s over it? [y/N] ' "${VERSION}"
    fi
  else
    printf 'Existing Crona binaries were found in %s.\n' "${INSTALL_DIR}"
    printf 'Install %s over them? [y/N] ' "${VERSION}"
  fi

  if [ ! -t 0 ]; then
    echo
    echo "Install cancelled. Re-run with CRONA_INSTALL_FORCE=1 to replace the existing install non-interactively." >&2
    exit 1
  fi

  read -r reply
  case "${reply}" in
    y|Y|yes|YES)
      return 0
      ;;
    *)
      echo "Install cancelled."
      exit 0
      ;;
  esac
}

detect_os() {
  case "$(uname -s)" in
    Darwin) echo "darwin" ;;
    Linux) echo "linux" ;;
    *)
      echo "Unsupported OS: $(uname -s)" >&2
      exit 1
      ;;
  esac
}

detect_arch() {
  case "$(uname -m)" in
    arm64|aarch64) echo "arm64" ;;
    x86_64|amd64) echo "amd64" ;;
    *)
      echo "Unsupported architecture: $(uname -m)" >&2
      exit 1
      ;;
  esac
}

verify_nonempty() {
  file_path="$1"
  if [ ! -s "${file_path}" ]; then
    echo "Downloaded file is empty: ${file_path}" >&2
    exit 1
  fi
}

is_interactive() {
  [ -t 1 ] || [ -t 2 ]
}

download_file() {
  label="$1"
  url="$2"
  output="$3"
  echo "Downloading ${label}..."
  if is_interactive; then
    curl -fL --show-error --progress-bar "${url}" -o "${output}"
  else
    curl -fsSL "${url}" -o "${output}"
  fi
}

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Required command not found: $1" >&2
    exit 1
  fi
}

verify_checksums() {
  subset_file="${TMP_DIR}/checksums.selected.txt"
  : > "${subset_file}"

  for file_name in "$@"; do
    line="$(grep "  ${file_name}\$" "${CHECKSUMS_FILE}" || true)"
    if [ -z "${line}" ]; then
      echo "checksums.txt is missing ${file_name}" >&2
      exit 1
    fi
    printf '%s\n' "${line}" >> "${subset_file}"
  done

  (
    cd "${TMP_DIR}"
    if command -v sha256sum >/dev/null 2>&1; then
      sha256sum -c "${subset_file}"
    elif command -v shasum >/dev/null 2>&1; then
      shasum -a 256 -c "${subset_file}"
    else
      echo "Neither sha256sum nor shasum is available to verify Crona downloads." >&2
      exit 1
    fi
  )
}

OS="$(detect_os)"
ARCH="$(detect_arch)"
CRONA_HOME_IS_OVERRIDE=0
if [ -n "${CRONA_HOME:-}" ]; then
  CRONA_HOME_IS_OVERRIDE=1
else
  CRONA_HOME="$(default_crona_home)"
fi
LEGACY_CRONA_HOME="$(legacy_crona_home)"
ASSETS_DIR="${CRONA_HOME}/assets/bundled"
BASE_URL="${CRONA_RELEASE_BASE_URL:-https://github.com/${REPO}/releases/download/${VERSION}}"
BUNDLE_NAME="crona-bundle-${VERSION}-${OS}-${ARCH}.zip"
ASSETS_NAME="crona-assets-${VERSION}.tar.gz"
BUNDLE_URL="${BASE_URL}/${BUNDLE_NAME}"
ASSETS_URL="${BASE_URL}/${ASSETS_NAME}"
CHECKSUMS_URL="${BASE_URL}/checksums.txt"

mkdir -p "${INSTALL_DIR}"
migrate_legacy_runtime_dir
mkdir -p "${ASSETS_DIR}"
TMP_DIR="$(mktemp -d "${CRONA_HOME}/install.XXXXXX" 2>/dev/null || mktemp -d "/tmp/crona-install.XXXXXX")"

INSTALLED_VERSION=""
if [ -f "${VERSION_FILE}" ]; then
  INSTALLED_VERSION="$(tr -d '\n' < "${VERSION_FILE}")"
fi

if [ -x "${INSTALL_DIR}/crona" ] || [ -x "${INSTALL_DIR}/crona-kernel" ] || [ -x "${INSTALL_DIR}/crona-tui" ]; then
  prompt_replace "${INSTALLED_VERSION}"
fi

stop_running_kernel_at "${CRONA_HOME}"
require_command curl
require_command unzip
require_command tar

CHECKSUMS_FILE="${TMP_DIR}/checksums.txt"
BUNDLE_FILE="${TMP_DIR}/${BUNDLE_NAME}"
ASSETS_FILE="${TMP_DIR}/${ASSETS_NAME}"
BUNDLE_DIR="${TMP_DIR}/bundle"

echo "Installing Crona ${VERSION} to ${INSTALL_DIR}"
download_file "checksums" "${CHECKSUMS_URL}" "${CHECKSUMS_FILE}"
download_file "bundle" "${BUNDLE_URL}" "${BUNDLE_FILE}"
download_file "assets" "${ASSETS_URL}" "${ASSETS_FILE}"

verify_nonempty "${CHECKSUMS_FILE}"
verify_nonempty "${BUNDLE_FILE}"
verify_nonempty "${ASSETS_FILE}"
echo "Verifying checksums..."
verify_checksums "${BUNDLE_NAME}" "${ASSETS_NAME}"

mkdir -p "${BUNDLE_DIR}"
unzip -q "${BUNDLE_FILE}" -d "${BUNDLE_DIR}"
CLI_FILE="${BUNDLE_DIR}/crona-${VERSION}-${OS}-${ARCH}"
KERNEL_FILE="${BUNDLE_DIR}/crona-kernel-${VERSION}-${OS}-${ARCH}"
TUI_FILE="${BUNDLE_DIR}/crona-tui-${VERSION}-${OS}-${ARCH}"
verify_nonempty "${CLI_FILE}"
verify_nonempty "${KERNEL_FILE}"
verify_nonempty "${TUI_FILE}"
chmod +x "${CLI_FILE}" "${KERNEL_FILE}" "${TUI_FILE}"
echo "Installing binaries..."
mv "${CLI_FILE}" "${INSTALL_DIR}/crona"
mv "${KERNEL_FILE}" "${INSTALL_DIR}/crona-kernel"
mv "${TUI_FILE}" "${INSTALL_DIR}/crona-tui"
rm -rf "${ASSETS_DIR}/export"
echo "Extracting bundled assets..."
tar -xzf "${ASSETS_FILE}" -C "${ASSETS_DIR}"
printf '%s\n' "${VERSION}" > "${VERSION_FILE}"

echo
echo "Installed:"
echo "  ${INSTALL_DIR}/crona"
echo "  ${INSTALL_DIR}/crona-kernel"
echo "  ${INSTALL_DIR}/crona-tui"
echo "  runtime data: ${CRONA_HOME}"
echo "  ${ASSETS_DIR}/export"
echo
echo "Make sure ${INSTALL_DIR} is on your PATH."
echo "Then run:"
echo "  crona"
